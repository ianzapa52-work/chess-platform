---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeFriendsSidebar from "../components/HomeFriendsSidebar";
import HomeRecentActivity from "../components/HomeRecentActivity";
import HomeRankingSidebar from "../components/HomeRankingSidebar";
---

<BaseLayout title="WELIKECHESS - Nuestro Ajedrez">
  <div class="fixed inset-0 flex flex-col bg-[#070707] text-zinc-300 font-sans overflow-hidden">
    
    <header class="h-16 border-b border-[#d4af37]/20 bg-black flex items-center justify-between px-6 z-50 shrink-0 shadow-[0_4px_20px_rgba(0,0,0,0.5)]">
      <div class="flex items-center gap-6">
        <div class="flex items-center gap-3">
          <img id="homeKing" src="/pieces/w_king.svg" class="w-8 h-8 drop-shadow-[0_0_10px_rgba(212,175,55,0.8)]" />
          <h1 class="text-2xl font-bold tracking-tighter text-white" style="font-family: 'Cinzel', serif;">
            WELIKE<span class="text-[#d4af37] drop-shadow-[0_0_5px_rgba(212,175,55,0.4)]">CHESS</span>
          </h1>
        </div>
        <nav class="hidden lg:flex items-center gap-1">
          {[
            { name: 'Play', url: '/play-online' },
            { name: 'Puzzles', url: '/puzzles' },
            { name: 'Ranking', url: '/ranking' },
            { name: 'Amigos', url: '/friends' }
          ].map((item) => (
            <a href={item.url} class="px-4 py-2 text-xs font-bold uppercase tracking-widest hover:text-[#d4af37] hover:bg-[#d4af37]/5 rounded-lg transition-all">
              {item.name}
            </a>
          ))}
          <button 
            onclick="window.dispatchEvent(new CustomEvent('open-history'))"
            class="px-4 py-2 text-xs font-bold uppercase tracking-widest text-[#d4af37] hover:bg-[#d4af37]/5 rounded-lg transition-all cursor-pointer bg-transparent border-none outline-none"
          >
            Historial
          </button>
        </nav>
      </div>
      
      <div class="flex items-center gap-6">
        <div class="hidden xl:flex items-center gap-6 border-x border-white/10 px-6 h-16 text-[10px] uppercase tracking-[0.2em]">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse shadow-[0_0_8px_#22c55e]"></span> 
            2,410 ONLINE
          </div>
        </div>
        <a href="/profile" class="flex items-center gap-3 bg-[#d4af37]/5 p-1.5 rounded-xl border border-[#d4af37]/20 hover:border-[#d4af37] transition-all group">
          <div class="pl-2 text-right">
            <p class="text-[9px] text-[#d4af37]/60 leading-none uppercase font-black">Tu Perfil</p>
            <p class="text-xs font-bold text-[#d4af37] group-hover:text-white transition-colors">1,650 ELO</p>
          </div>
          <div class="w-8 h-8 rounded-lg bg-[#d4af37] flex items-center justify-center text-black font-black text-xs">JD</div>
        </a>
      </div>
    </header>

    <div class="flex-grow grid grid-cols-12 overflow-hidden">
      
      <HomeFriendsSidebar client:load />

      <main class="col-span-12 xl:col-span-7 flex flex-col overflow-y-auto custom-scrollbar bg-[radial-gradient(circle_at_top,#1a1a1a_0%,#050505_100%)] shadow-inner">
        <section class="p-8 max-w-5xl mx-auto w-full pt-8"> 
          <div class="mb-8 border-l-2 border-[#d4af37] pl-6">
            <h2 class="text-5xl font-light text-white italic tracking-tight" style="font-family: 'Marcellus', serif;">
              ¿Cuál es tu <span class="text-[#d4af37]">próximo movimiento?</span>
            </h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
            <a href="/play-online" class="group relative h-44 rounded-2xl border border-[#d4af37]/30 bg-gradient-to-br from-[#d4af37]/10 via-transparent to-transparent p-6 overflow-hidden flex flex-col justify-between hover:border-[#d4af37] hover:shadow-[0_0_30px_rgba(212,175,55,0.15)] hover:-translate-y-1 transition-all duration-300">
              <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-30 group-hover:scale-125 group-hover:rotate-6 transition-all duration-700 ease-out">
                <img src="/pieces/w_queen.svg" class="w-32" />
              </div>
              <div class="relative z-10">
                <span class="text-[#d4af37] text-[10px] font-black uppercase tracking-[0.4em]">Multiplayer</span>
                <h3 class="text-2xl font-bold text-white mt-1 uppercase tracking-tighter group-hover:translate-x-1 transition-transform">Jugar Online</h3>
              </div>
              <p class="text-xs text-zinc-400">Compite contra oponentes reales.</p>
            </a>

            <a href="/play-ia" class="group relative h-44 rounded-2xl border border-[#d4af37]/30 bg-gradient-to-br from-[#d4af37]/10 via-transparent to-transparent p-6 overflow-hidden flex flex-col justify-between hover:border-[#d4af37] hover:shadow-[0_0_30px_rgba(212,175,55,0.15)] hover:-translate-y-1 transition-all duration-300">
               <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-30 group-hover:scale-110 group-hover:-rotate-12 transition-all duration-700 ease-out">
                <img src="/pieces/w_king.svg" class="w-32" />
              </div>
              <div class="relative z-10">
                <span class="text-[#d4af37] text-[10px] font-black uppercase tracking-[0.4em]">Stockfish v16</span>
                <h3 class="text-2xl font-bold text-white mt-1 uppercase tracking-tighter group-hover:translate-x-1 transition-transform">Jugar vs IA</h3>
              </div>
              <p class="text-xs text-zinc-400">Entrena contra la máquina.</p>
            </a>

            <a href="/play-local" class="group relative h-32 rounded-2xl border border-[#d4af37]/30 bg-gradient-to-br from-[#d4af37]/10 via-transparent to-transparent p-6 flex items-center gap-6 hover:border-[#d4af37] hover:shadow-[0_0_30px_rgba(212,175,55,0.15)] hover:-translate-y-1 transition-all duration-300">
              <div class="w-12 h-12 bg-[#d4af37]/10 rounded-xl flex items-center justify-center text-2xl group-hover:scale-125 group-hover:bg-[#d4af37]/20 transition-all duration-300">🏠</div>
              <div>
                <h4 class="text-lg font-bold text-white uppercase tracking-tighter group-hover:text-[#d4af37] transition-colors">Partida Local</h4>
                <p class="text-[10px] text-zinc-500 uppercase tracking-widest font-bold mt-0.5">Reto en persona</p>
              </div>
            </a>

            <a href="/puzzles" class="group relative h-32 rounded-2xl border border-[#d4af37]/30 bg-gradient-to-br from-[#d4af37]/10 via-transparent to-transparent p-6 flex items-center gap-6 hover:border-[#d4af37] hover:shadow-[0_0_30px_rgba(212,175,55,0.15)] hover:-translate-y-1 transition-all duration-300">
              <div class="w-12 h-12 bg-[#d4af37]/10 rounded-xl flex items-center justify-center text-2xl group-hover:rotate-[15deg] group-hover:scale-125 group-hover:bg-[#d4af37]/20 transition-all duration-300">🧩</div>
              <div>
                <h4 class="text-lg font-bold text-white uppercase tracking-tighter group-hover:text-[#d4af37] transition-colors">Puzzles</h4>
                <p class="text-[10px] text-zinc-500 uppercase tracking-widest font-bold mt-0.5">Resuelve tácticas</p>
              </div>
            </a>
          </div>

          <div class="bg-[#d4af37]/5 border border-[#d4af37]/30 rounded-2xl p-6 relative overflow-hidden shadow-2xl hover:border-[#d4af37]/50 transition-all duration-500">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xs font-black uppercase text-[#d4af37] tracking-[0.2em] flex items-center gap-2">
                  <span class="w-1.5 h-1.5 bg-[#d4af37] rounded-full animate-pulse"></span> Actividad Reciente
                </h3>
                <button 
                  onclick="window.dispatchEvent(new CustomEvent('open-history'))" 
                  class="text-[10px] text-zinc-500 hover:text-[#d4af37] uppercase font-bold transition-all cursor-pointer bg-transparent border-none outline-none"
                >
                  Ver todo
                </button>
            </div>
            
            <HomeRecentActivity client:load />
            
          </div>
        </section>
      </main>

      <aside class="hidden lg:flex col-span-3 bg-[#0a0a0a] border-l border-[#d4af37]/10 flex-col overflow-hidden relative">
        <div class="absolute left-0 top-0 w-[1px] h-full bg-gradient-to-b from-transparent via-[#d4af37]/20 to-transparent"></div>
        <div class="mt-4 p-8 space-y-10 overflow-y-auto custom-scrollbar">
          <HomeRankingSidebar client:load />
        </div>
      </aside>

    </div>
  </div>
</BaseLayout>

<style is:global>
  html, body {
    margin: 0 !important;
    padding: 0 !important;
    height: 100% !important;
    width: 100% !important;
    overflow: hidden !important;
    background-color: #000;
  }
  .custom-scrollbar::-webkit-scrollbar { width: 3px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(212, 175, 55, 0.2); border-radius: 10px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #d4af37; }
</style>