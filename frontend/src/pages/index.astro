---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeFriendsSidebar from "../components/HomeFriendsSidebar";
import HomeRecentActivity from "../components/HomeRecentActivity";
import HomeRankingSidebar from "../components/HomeRankingSidebar";
---

<BaseLayout title="WELIKECHESS - Nuestro Ajedrez">
  <div class="flex flex-col bg-[#070707] text-zinc-300 font-sans overflow-hidden">
    
    <div class="flex-grow grid grid-cols-12 overflow-hidden">
      
      <aside class="col-span-2 hidden xl:flex border-r border-[#d4af37]/10 bg-[#0a0a0a] flex-col overflow-hidden">
          <HomeFriendsSidebar client:load />
      </aside>

      <main class="col-span-12 xl:col-span-8 flex flex-col overflow-y-auto custom-scrollbar bg-[radial-gradient(circle_at_top,#1a1a1a_0%,#050505_100%)]">
        <section class="p-8 md:p-12 max-w-[1400px] mx-auto w-full pt- pb-16"> 
          
          <div class="mb-12 border-l-4 border-[#d4af37] pl-8 py-2 bg-gradient-to-r from-[#d4af37]/5 to-transparent rounded-r-xl">
            <p class="text-[11px] font-black uppercase text-[#d4af37]/70 tracking-[0.5em] mb-1">Nuestro Ajedrez</p>
            <h2 class="text-6xl font-light text-white italic tracking-tight leading-none" style="font-family: 'Marcellus', serif;">
              ¿Cuál será<span class="text-[#d4af37] font-normal"> tu próximo movimiento?</span>
            </h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            
            <a href="/play-online" class="group relative h-64 rounded-3xl border border-[#d4af37]/20 bg-black/40 p-8 overflow-hidden flex flex-col justify-between hover:border-[#d4af37] hover:shadow-[0_0_50px_rgba(212,175,55,0.2)] hover:-translate-y-2 transition-all duration-500 shadow-xl">
              <div class="absolute -top-10 -right-10 opacity-10 group-hover:opacity-30 group-hover:scale-110 group-hover:rotate-6 transition-all duration-700">
                <img src="/pieces/w_queen.svg" class="w-48" />
              </div>
              <div class="relative z-10">
                <div class="flex items-center gap-3 mb-2">
                  <span class="w-2.5 h-2.5 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_#22c55e]"></span>
                  <span class="text-[#d4af37] text-xs font-black uppercase tracking-[0.4em]">Arena Multiplayer</span>
                </div>
                <h3 class="text-3xl font-bold text-white uppercase tracking-tighter leading-tight group-hover:text-[#d4af37] transition-colors">Jugar Online</h3>
              </div>
              <div class="relative z-10 bg-black/50 backdrop-blur-sm p-4 rounded-xl border border-white/5 mt-auto">
                <p class="text-sm text-zinc-300">Compite contra el mundo en tiempo real.</p>
                <span class="text-[10px] text-zinc-500 uppercase font-bold mt-2 block tracking-widest">3,210 Jugadores activos</span>
              </div>
            </a>

            <a href="/play-ia" class="group relative h-64 rounded-3xl border border-[#d4af37]/20 bg-black/40 p-8 overflow-hidden flex flex-col justify-between hover:border-[#d4af37] hover:shadow-[0_0_50px_rgba(212,175,55,0.2)] hover:-translate-y-2 transition-all duration-500 shadow-xl">
               <div class="absolute -top-10 -right-10 opacity-10 group-hover:opacity-30 group-hover:scale-105 group-hover:-rotate-12 transition-all duration-700">
                <img src="/pieces/w_king.svg" class="w-48" />
              </div>
              <div class="relative z-10">
                <span class="text-[#d4af37] text-xs font-black uppercase tracking-[0.4em]">Entrenamiento IA</span>
                <h3 class="text-3xl font-bold text-white mt-1 uppercase tracking-tighter leading-tight group-hover:text-[#d4af37] transition-colors">Desafiar IA</h3>
              </div>
              <div class="relative z-10 bg-black/50 backdrop-blur-sm p-4 rounded-xl border border-white/5 mt-auto">
                <p class="text-sm text-zinc-300">Stockfish v16 listo para ponerte a prueba.</p>
                <span class="text-[10px] text-zinc-500 uppercase font-bold mt-2 block tracking-widest">Niveles 1-20 adaptativos</span>
              </div>
            </a>

            <a href="/play-local" class="group relative h-64 rounded-3xl border border-[#d4af37]/20 bg-black/40 p-8 overflow-hidden flex flex-col justify-between hover:border-[#d4af37] hover:shadow-[0_0_50px_rgba(212,175,55,0.2)] hover:-translate-y-2 transition-all duration-500 shadow-xl">
              <div class="absolute -top-10 -right-10 opacity-10 group-hover:opacity-30 group-hover:scale-110 transition-all duration-700">
                <img src="/pieces/w_rook.svg" class="w-48" />
              </div>
              <div class="relative z-10">
                <span class="text-[#d4af37] text-xs font-black uppercase tracking-[0.4em]">En Persona</span>
                <h3 class="text-3xl font-bold text-white mt-1 uppercase tracking-tighter leading-tight group-hover:text-[#d4af37] transition-colors">Duelo Local</h3>
              </div>
              <div class="relative z-10 bg-black/50 backdrop-blur-sm p-4 rounded-xl border border-white/5 mt-auto">
                <p class="text-sm text-zinc-300">Tablero virtual perfecto para jugar cara a cara.</p>
                <span class="text-[10px] text-zinc-500 uppercase font-bold mt-2 block tracking-widest">Incluye reloj de torneo</span>
              </div>
            </a>
          </div>

          <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
            <div class="bg-black/50 border border-[#d4af37]/15 rounded-3xl p-8 relative overflow-hidden shadow-2xl transition-all duration-500 hover:border-[#d4af37]/40 group">
              <div class="relative z-10">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-white/5">
                    <h3 class="text-sm font-black uppercase text-[#d4af37] tracking-[0.3em] flex items-center gap-3">
                      <span class="w-2 h-2 bg-[#d4af37] rounded-full animate-pulse"></span> Actividad Reciente
                    </h3>
                </div>
                <HomeRecentActivity client:load />
              </div>
            </div>

            <div class="bg-black/50 border border-[#d4af37]/15 rounded-3xl p-8 relative overflow-hidden shadow-2xl transition-all duration-500 hover:border-[#d4af37]/40 group flex flex-col">
              <div class="relative z-10 flex-grow flex flex-col">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-white/5">
                    <h3 class="text-sm font-black uppercase text-[#d4af37] tracking-[0.3em] flex items-center gap-3">
                      <span class="w-2 h-2 bg-[#d4af37] rounded-full animate-pulse"></span> Desafío Táctico
                    </h3>
                </div>
                
                <div class="flex gap-6 items-center flex-grow bg-[#d4af37]/5 rounded-2xl p-6 border border-[#d4af37]/10">
                  <div class="w-24 h-24 rounded-lg bg-black/40 border border-[#d4af37]/20 flex items-center justify-center text-5xl">🧩</div>
                  <div class="flex-grow">
                    <p class="text-[11px] text-[#d4af37]/70 font-black uppercase tracking-widest">Dificultad Media</p>
                    <h4 class="text-xl font-bold text-white uppercase tracking-tight mt-1">Ganan Blancas</h4>
                    <p class="text-xs text-zinc-400 mt-1">Encuentra la secuencia de mate forzado.</p>
                  </div>
                  <a href="/puzzles" class="px-6 py-3 bg-[#d4af37] text-black rounded-full font-bold text-xs uppercase tracking-widest hover:bg-white transition-colors shadow-lg active:scale-95">Resolver</a>
                </div>
              </div>
            </div>
          </div>

        </section>
      </main>

      <aside class="hidden xl:flex col-span-2 bg-[#0a0a0a] border-l border-[#d4af37]/10 flex-col overflow-hidden relative">
        <div class="absolute left-0 top-0 w-[1px] h-full bg-gradient-to-b from-transparent via-[#d4af37]/20 to-transparent"></div>
        <div class="mt-4 px-2.5 py-4 space-y-6 overflow-y-auto custom-scrollbar text-[0.95em]">
          <HomeRankingSidebar client:load />
        </div>
      </aside>

    </div>
  </div>
</BaseLayout>

<style is:global>
  html, body {
    margin: 0 !important;
    padding: 0 !important;
    height: 100% !important;
    width: 100% !important;
    overflow: hidden !important;
    background-color: #000;
  }
  .custom-scrollbar::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(212, 175, 55, 0.15); border-radius: 10px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #d4af37; }
</style>