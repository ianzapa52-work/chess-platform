---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="WELIKECHESS - Ranking Global">

  <div class="max-w-7xl mx-auto px-2 sm:px-6 py-8 md:py-16">

    <h1
      class="text-4xl md:text-7xl font-black mb-10 text-center
             bg-gradient-to-b from-[#d4af37] via-[#f2d47e] to-[#996515]
             bg-clip-text text-transparent drop-shadow-[0_2px_15px_rgba(212,175,55,0.4)]"
      style="font-family: 'Cinzel', serif;"
    >
      Ranking Global
    </h1>

    <div id="ranking-container" class="ranking-panel">
      <div id="loadingRanking" class="flex flex-col items-center justify-center py-10 gap-4">
        <div class="w-10 h-10 border-4 border-yellow-600/20 border-t-yellow-500 rounded-full animate-spin"></div>
        <p class="text-gray-400 text-xs tracking-[0.2em] uppercase animate-pulse">
          Cargando Maestros...
        </p>
      </div>
    </div>

  </div>

  <script>
    import "../scripts/ranking.js";
  </script>

</BaseLayout>

<style>
  /* --- PANEL PRINCIPAL --- */
  .ranking-panel {
    background: rgba(10, 10, 10, 0.9);
    border: 2px solid rgba(212, 175, 55, 0.3);
    border-radius: 20px;
    padding: 0.75rem; /* Padding mínimo para no desperdiciar espacio */
    backdrop-filter: blur(20px);
    max-width: 1150px;
    margin: 0 auto;
    box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.9);
  }

  @media (min-width: 768px) {
    .ranking-panel {
      border-radius: 40px;
      padding: 3rem;
    }
  }

  /* --- FILA DEL RANKING --- */
  :global(.ranking-link) {
    text-decoration: none;
    display: block;
    margin-bottom: 0.5rem;
    width: 100%; /* Asegura que no se pase del padre */
  }

  :global(.ranking-row) {
    display: flex;
    align-items: center;
    gap: 0.5rem; /* Gap muy pequeño en móvil */
    padding: 0.75rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(212, 175, 55, 0.1);
    border-radius: 15px;
    transition: all 0.3s ease;
  }

  @media (min-width: 768px) {
    :global(.ranking-row) {
      gap: 2.5rem;
      padding: 2rem 3rem;
      border-radius: 35px;
      margin-bottom: 1.5rem;
    }
    :global(.ranking-link:hover .ranking-row) {
      transform: scale(1.01) translateX(10px);
      background: rgba(212, 175, 55, 0.08);
      border-color: #ffd700;
    }
  }

  /* --- POSICIÓN (Wrapper estrecho en móvil) --- */
  :global(.rank-position-wrapper) {
    width: 40px; /* Ancho fijo pequeño para móvil */
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (min-width: 768px) {
    :global(.rank-position-wrapper) { width: 120px; }
  }

  :global(.rank-medal-img) {
    width: 30px;
    height: auto;
  }

  @media (min-width: 768px) {
    :global(.rank-medal-img) { width: 85px; }
  }

  :global(.rank-number) {
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    color: #666;
  }

  @media (min-width: 768px) {
    :global(.rank-number) { font-size: 1.4rem; margin-top: 5px; }
  }

  /* --- AVATAR --- */
  :global(.rank-visuals) {
    position: relative;
    flex-shrink: 0;
  }

  :global(.rank-avatar) {
    width: 45px;
    height: 45px;
    border-radius: 10px;
    object-fit: cover;
    border: 1px solid rgba(255,255,255,0.1);
  }

  @media (min-width: 768px) {
    :global(.rank-avatar) {
      width: 100px; height: 100px;
      border-radius: 24px; border-width: 3px;
    }
  }

  /* Bandera mini en móvil */
  :global(.flag-wrapper) {
    position: absolute;
    bottom: -2px;
    right: -2px;
    width: 16px;
    height: 11px;
    border-radius: 2px;
    border: 1px solid #000;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    :global(.flag-wrapper) { width: 38px; height: 26px; border-radius: 6px; border-width: 2.5px; }
  }

  /* --- INFO (Nombre y Tier) --- */
  :global(.rank-info) {
    flex-grow: 1;
    min-width: 0; /* CRUCIAL para que el truncado de texto funcione */
    display: flex;
    flex-direction: column;
  }

  :global(.rank-name) {
    font-family: 'Cinzel', serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: white;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis; /* Si el nombre es largo, pone "..." */
  }

  @media (min-width: 768px) {
    :global(.rank-name) { font-size: 2.2rem; }
  }

  :global(.rank-tier) {
    font-size: 0.5rem;
    color: #d4af37;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  @media (min-width: 768px) {
    :global(.rank-tier) {
      font-size: 0.8rem; padding: 4px 12px; border-radius: 8px;
      background: rgba(212, 175, 55, 0.1); border: 1px solid rgba(212, 175, 55, 0.3);
      margin-top: 5px; align-self: flex-start;
    }
  }

  /* Ocultar stats en móviles muy pequeños para ahorrar espacio */
  :global(.rank-stats) { display: none; }
  @media (min-width: 768px) {
    :global(.rank-stats) { display: flex; color: #888; font-size: 1rem; gap: 12px; margin-top: 8px; }
  }

  /* --- CAJA DE ELO --- */
  :global(.rank-elo-box) {
    background: rgba(212, 175, 55, 0.05);
    padding: 6px 10px;
    border-radius: 10px;
    border: 1px solid rgba(212, 175, 55, 0.3);
    text-align: center;
    flex-shrink: 0; /* No permite que se encoja */
  }

  @media (min-width: 768px) {
    :global(.rank-elo-box) {
      background: linear-gradient(135deg, #1a1a1a 0%, #050505 100%);
      padding: 18px 30px; border-radius: 25px; min-width: 150px;
    }
  }

  :global(.rank-elo-val) {
    color: #ffd700;
    font-weight: 900;
    font-size: 1rem;
    font-family: 'Cinzel', serif;
  }

  @media (min-width: 768px) {
    :global(.rank-elo-val) { font-size: 2.6rem; }
  }

  :global(.rank-elo-label) { display: none; } /* Ocultamos "ELO" label en móvil */
  @media (min-width: 768px) {
    :global(.rank-elo-label) { display: block; font-size: 0.75rem; color: #555; letter-spacing: 3px; }
  }

  /* Animación de entrada */
  @keyframes slideIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  :global(.ranking-link) { animation: slideIn 0.4s ease-out forwards; }
</style>