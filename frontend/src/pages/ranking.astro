---
import BaseLayout from "../layouts/BaseLayout.astro";
import RankingForm from "../components/RankingForm";
---

<BaseLayout title="Ranking Global | WELIKECHESS">
  <div class="h-[calc(100vh-80px)] w-full flex flex-col justify-end pb-10 relative overflow-hidden bg-[#050505]">
    
    {/* LUCES DE FONDO AMBIENTALES */}
    <div class="absolute top-[-20%] left-[-10%] w-[60%] h-[60%] bg-[#d4af37]/5 rounded-full blur-[160px]"></div>
    <div class="absolute bottom-[-20%] right-[-10%] w-[60%] h-[60%] bg-[#d4af37]/5 rounded-full blur-[160px]"></div>

    {/* HEADER TÉCNICO (Opcional, se ve muy Pro) */}
    <div class="max-w-[1800px] mx-auto w-full px-14 py-4 flex justify-between items-center opacity-30 select-none pointer-events-none">
      <div class="flex items-center gap-6">
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse shadow-[0_0_8px_#22c55e]"></div>
          <span class="text-[9px] text-white tracking-[0.5em] font-bold uppercase">Servidor: Online</span>
        </div>
        <span class="text-white opacity-20 text-[9px]">|</span>
        <span class="text-[9px] text-white tracking-[0.5em] font-light uppercase italic">Protocolo ELO_SYNC_v4.2</span>
      </div>
      
      <div class="flex items-center gap-8">
        <span class="text-[9px] text-white tracking-[0.5em] font-light uppercase">Latencia: 12ms</span>
        <span class="text-[9px] text-white tracking-[0.5em] font-bold uppercase">Región: UE-Central</span>
      </div>
    </div>

    {/* EL COMPONENTE REACT */}
    <RankingForm client:load />

  </div>
</BaseLayout>

<style is:global>
  body { overflow: hidden !important; }
  .custom-scrollbar::-webkit-scrollbar { display: none; }
</style>