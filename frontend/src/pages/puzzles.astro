---
import BaseLayout from "../layouts/BaseLayout.astro";
import AchievementToast from "../components/AchievementToast";
---

<BaseLayout title="WELIKECHESS - Puzzles Premium">
  <div class="main-screen">
    <div class="game-wrapper">
      
      <aside class="side-panel">
        <div class="ui-card objective-card">
          <div class="card-header">
            <span class="icon">🎯</span>
            <span class="title">OBJETIVO</span>
          </div>
          <div id="puzzleObjective" class="objective-text">Cargando...</div>
        </div>
        
        <div class="status-container">
          <div id="puzzle-feedback" class="status-badge">TU TURNO</div>
        </div>

        <button id="nextPuzzle" class="premium-btn">
          <span>SIGUIENTE PUZZLE</span>
          <div class="btn-glow"></div>
        </button>
      </aside>

      <section class="board-container">
        <div class="board-frame">
          <div class="coords-h">
            <span>A</span><span>B</span><span>C</span><span>D</span><span>E</span><span>F</span><span>G</span><span>H</span>
          </div>
          <div class="board-flex">
            <div class="coords-v">
              <span>8</span><span>7</span><span>6</span><span>5</span><span>4</span><span>3</span><span>2</span><span>1</span>
            </div>
            <div id="board" class="compact-board"></div>
          </div>
        </div>
      </section>

      <aside class="side-panel">
        <div class="ui-card progress-card">
          <div class="card-header">PROGRESO</div>
          <div class="stats-wrapper">
            <div class="stat-main">
              <span id="solved-count" class="stat-number">0</span>
              <p class="stat-label">Puzzles Resueltos</p>
            </div>
          </div>
        </div>
        <AchievementToast client:load />
      </aside>

    </div>
  </div>

  <script>
    import "../scripts/puzzles.ts";
  </script>
</BaseLayout>

<style is:global>
  .main-screen {
    min-height: calc(100vh - 80px);
    display: flex;
    justify-content: center;
    align-items: center; 
    padding: 20px;
  }

  .game-wrapper {
    display: grid; 
    grid-template-columns: 260px 680px 260px; 
    gap: 30px; 
    align-items: center;
  }

  .board-frame {
    background: rgba(10, 31, 22, 0.8);
    padding: 15px;
    border-radius: 8px;
    border: 1px solid rgba(46, 204, 113, 0.2);
    box-shadow: 0 20px 50px rgba(0,0,0,0.6);
  }

  .compact-board {
    width: 600px;
    height: 600px;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(8, 1fr);
    border: 4px solid #1a1a1a;
    user-select: none;
  }

  .square { 
    width: 100%; height: 100%; 
    display: flex; justify-content: center; align-items: center; 
    position: relative;
    transition: background-color 0.3s ease;
    outline: none !important;
    -webkit-tap-highlight-color: transparent;
  }

  .square.light { background: #eeeed2; }
  .square.dark { background: #769656; }

  .square.legal-move {
    box-shadow: inset 0 0 0 5px #13eb6d !important;
    z-index: 10;
  }

  .square.selected {
    box-shadow: none !important;
    outline: none !important;
  }

  .square.success-flash { background: rgba(2, 255, 107, 0.8) !important; }
  
  .square.error-flash { 
    background: rgba(236, 41, 20, 0.9) !important; 
    transition: background-color 0.2s ease;
  }

  .piece { 
    width: 90%; height: 90%; cursor: grab; z-index: 5;
    filter: drop-shadow(0 4px 4px rgba(0,0,0,0.4));
  }

  .side-panel { display: flex; flex-direction: column; gap: 20px; }
  .ui-card {
    background: linear-gradient(145deg, rgba(13, 43, 31, 0.9), rgba(7, 24, 17, 0.95));
    border: 1px solid rgba(46, 204, 113, 0.3);
    border-radius: 12px; padding: 24px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    position: relative; overflow: hidden; backdrop-filter: blur(5px);
  }
  .card-header {
    display: flex; align-items: center; gap: 8px;
    font-family: 'Cinzel', serif; color: #2ecc71;
    font-size: 0.85rem; letter-spacing: 1px; margin-bottom: 15px;
  }
  .objective-text { font-size: 1.1rem; color: #ffffff; font-weight: 500; }
  .status-badge {
    background: rgba(10, 31, 22, 0.8); border: 1px solid rgba(46, 204, 113, 0.5);
    color: #2ecc71; text-align: center; padding: 16px; border-radius: 8px;
    font-weight: 800; letter-spacing: 2px;
  }
  .premium-btn {
    background: #1a1a1a; border: 1px solid #2ecc71; color: #2ecc71;
    padding: 16px; border-radius: 8px; font-family: 'Cinzel', serif;
    font-weight: bold; cursor: pointer;
  }
  .stat-number { display: block; font-size: 3.2rem; font-weight: 900; color: #f1c40f; text-align: center; }
  .stat-label { color: #ccc; font-size: 0.75rem; text-transform: uppercase; text-align: center; }
  .coords-h, .coords-v { color: #2ecc71; font-size: 0.75rem; font-weight: bold; opacity: 0.6; }
  .coords-h { display: flex; justify-content: space-around; padding-bottom: 5px; padding-left: 20px; }
  .coords-v { display: flex; flex-direction: column; justify-content: space-around; width: 20px; padding-right: 5px; }
  .board-flex { display: flex; }
</style>