---
import "../styles/global.css";
import ModalManager from "../components/modals/ModalManager";
const { title = "WELIKECHESS" } = Astro.props;
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/w_king.svg" />
    
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Inter:wght@300;400;500;700&display=swap" rel="stylesheet">

    <style is:inline>
      /* Bloqueo de layout para evitar saltos */
      html { background-color: #050505; overflow-y: scroll; }
      body { margin: 0; padding: 0; visibility: hidden; }
      .dark-mode body { visibility: visible; }
      header { height: 80px; }
      @media (min-width: 768px) { header { height: 96px; } }
    </style>

    <script is:inline>
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
      window.scrollTo(0, 0);

      (function() {
        const savedTheme = localStorage.getItem("theme") || "dark";
        if (savedTheme === "dark") document.documentElement.classList.add("dark-mode");
      })();
    </script>

    <title>{title}</title>
  </head>

  <body class="antialiased selection:bg-[#d4af37] selection:text-black bg-[#050505]">
    
    <div class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-zinc-900 via-black to-black opacity-40 contain-paint"></div>

    <header class="fixed top-0 left-0 w-full h-20 md:h-24 bg-black/60 grid grid-cols-3 items-center px-4 md:px-10 z-[60] backdrop-blur-xl border-b border-white/5">
      
      <div class="justify-self-start">
        <a href="/" class="relative group block">
          <h1 class="text-xl md:text-2xl font-light tracking-[0.3em] text-[#fefcf0] transition-colors duration-300 group-hover:text-white" style="font-family: 'Cinzel', serif;">
            WELIKE<span class="font-black text-[#d4af37] group-hover:brightness-125 transition-all">CHESS</span>
          </h1>
          <div class="absolute -bottom-1 left-0 w-full h-[1px] bg-white/10 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-center"></div>
        </a>
      </div>

      <div class="flex items-center justify-self-center">
        <nav class="hidden lg:flex items-center gap-1 bg-zinc-900/50 p-1.5 rounded-xl border border-white/10 backdrop-blur-md">
          <div class="flex items-center">
            <a href="/play-online" class="nav-link-v2">Online</a>
            <a href="/play-ia" class="nav-link-v2">IA</a>
            <a href="/play-local" class="nav-link-v2">Local</a>
            <a href="/puzzles" class="nav-link-v2">Puzzles</a>
          </div>
          
          <div class="w-[1px] h-4 bg-white/10 mx-2"></div>
          
          <div class="flex items-center">
            <a href="/ranking" class="nav-link-v2">Ranking</a>
            <a href="/friends" class="nav-link-v2">Amigos</a>
            <button 
              onclick="window.dispatchEvent(new CustomEvent('open-history'))" 
              class="nav-link-v2"
            >
              Historial
            </button>
          </div>
        </nav>
      </div>

      <div class="flex items-center justify-end gap-4 justify-self-end">
        <button 
          onclick="window.dispatchEvent(new CustomEvent('open-login'))"
          class="hidden sm:flex items-center justify-center px-6 py-2 rounded-lg border border-white/10 text-white/70 text-[10px] font-bold uppercase tracking-[0.15em] hover:border-[#d4af37]/50 hover:text-white transition-all duration-300"
        >
          Acceso
        </button>

        <a href="/profile" class="flex items-center gap-3 bg-white/5 pl-4 pr-1.5 py-1.5 rounded-xl border border-white/5 hover:border-[#d4af37]/30 transition-all group">
          <span class="text-[10px] font-bold text-zinc-400 group-hover:text-[#d4af37] uppercase tracking-widest hidden xl:block">Mi Perfil</span>
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-[#d4af37] to-[#996515] flex items-center justify-center text-black font-black text-[11px] shadow-lg">
            IZ
          </div>
        </a>

        <button 
          onclick="window.dispatchEvent(new CustomEvent('open-settings'))"
          class="group p-2 rounded-lg border border-white/5 bg-white/5 hover:border-[#d4af37]/40 transition-all"
        >
          <img src="/assets/gear.png" class="w-4.5 h-4.5 opacity-50 group-hover:opacity-100 group-hover:rotate-45 transition-all duration-500 brightness-200" alt="Ajustes" />
        </button>
      </div>
    </header>

    <main class="relative min-h-screen pt-20 md:pt-24 block">
      <slot />
    </main>

    <ModalManager client:load />

  </body>
</html>

<style is:global>
  @reference "../styles/global.css";

  :root { 
    --bg-main: #050505; 
    --accent: #d4af37;
  }
  
  body { 
    margin: 0;
    background-color: var(--bg-main); 
    color: #f0f0f0; 
    font-family: 'Inter', sans-serif;
    transition: none !important;
  }

  /* Estilo Neo-Brutalist para links centrales */
  .nav-link-v2 {
    @apply px-4 py-2 text-[10px] font-bold uppercase tracking-[0.1em] text-zinc-400 
           rounded-lg transition-all duration-200 relative outline-none;
    font-family: 'Inter', sans-serif;
  }

  .nav-link-v2:hover {
    @apply text-white bg-white/10;
  }

  /* Scrollbar Minimalista */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #000; }
  ::-webkit-scrollbar-thumb { 
    background: #333; 
    border-radius: 0px;
  }
  ::-webkit-scrollbar-thumb:hover { background: #d4af37; }

  a, button { cursor: pointer !important; }

  main { contain: layout; }
</style>